# Claude subscription auth -- no API key needed
# Get your OAuth token: cat ~/.claude/auth.json (or wherever Claude Code stores it)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# Optional: override model tiers
# ANTHROPIC_SMALL_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MEDIUM_MODEL=claude-sonnet-4-6
# ANTHROPIC_LARGE_MODEL=claude-opus-4-6

# OpenMemory MCP server (on Lenovo)
# LAN: http://10.0.0.21:8080/mcp | Tailscale: http://100.91.167.11:8080/mcp
OPENMEMORY_URL=http://100.91.167.11:8080/mcp

# Temporal address (default: localhost:7233 when running docker compose)
TEMPORAL_ADDRESS=localhost:7233
